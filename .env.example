# ── Frontend (Vercel / Docker) ───────────────────────────────────────────────
# Production: set to your Render (or other) backend public URL
NEXT_PUBLIC_API_URL=https://kospi-screener-api.onrender.com

# Server-side Next.js proxy (local dev / Docker compose)
BACKEND_URL=http://127.0.0.1:8000

# ── Backend (Render / Docker) ────────────────────────────────────────────────
DEBUG=false

# Primary frontend origin (also merged into CORS allowlist)
FRONTEND_URL=https://your-app.vercel.app

# Extra allowed origins — comma-separated (preview URLs, custom domains)
CORS_ORIGINS=https://your-app.vercel.app,https://your-app-git-main.vercel.app

# Allow all Vercel preview deployments (*.vercel.app)
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Optional Bayesian / universe overrides
# PRIOR_UP_PROB=0.52
# UNIVERSE_LIMIT=50

# pykrx KRX API (recommended for production data quality)
# KRX_ID=your_id
# KRX_PW=your_password
