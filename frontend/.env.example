# Local dev: leave unset to use same-origin proxy (next.config.js rewrite / route handler)
# NEXT_PUBLIC_API_URL=

# Vercel / production: public backend URL (Render, Railway, etc.)
# NEXT_PUBLIC_API_URL=https://kospi-screener-api.onrender.com

# Server-side proxy only (optional, when NEXT_PUBLIC_API_URL is unset)
# BACKEND_URL=http://127.0.0.1:8000
